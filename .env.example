# =========================================================================
# CivicHero Environment Variables Template
# =========================================================================

# --- Google Gemini AI & General ---
# Required for automated AI visual and text analysis of reported issues.
# Injected automatically in AI Studio at runtime when set in the user Secrets panel.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# The deployment or development URL. Injected automatically by AI Studio.
APP_URL="https://your-applet-domain.run.app"


# --- PostgreSQL Database Credentials (Cloud SQL or Local Postgres) ---
# The host address where the Postgres database is running.
SQL_HOST="127.0.0.1"

# The name of the database.
SQL_DB_NAME="civichero"

# Credentials used for standard application queries (read/write runtime queries)
SQL_USER="postgres"
SQL_PASSWORD="your-strong-password"

# Credentials with schema/admin privileges used by Drizzle Kit to migrate or update schema
SQL_ADMIN_USER="postgres"
SQL_ADMIN_PASSWORD="your-strong-password"
